# Copy this file to .env and fill in the values before running docker compose up
# NEVER commit .env to version control

# Secret for the admin panel at /admin
# Change this to a strong random string in production
ADMIN_SECRET=change-this-in-production

# Full public URL of your deployment (used to generate the QR code and controller links)
# Must match the subdomain configured in Nginx Proxy Manager
PUBLIC_URL=https://pachp.ltn.re
